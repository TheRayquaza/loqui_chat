{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "outDir": "build",
        "strict": true,
        "esModuleInterop": true,
	"sourceMap" : true
    },
    "ts-node": {
        "transpileOnly": true,
        "files": true,
        "compilerOptions": {
            "rootDir": "."
        }
    },
    "include": [
        "src",
        "package.json"
    ],
    "exclude": [
        "node_modules",
    ]
}
